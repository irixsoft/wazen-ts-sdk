{
  "name": "@wazen/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/Node.js SDK for the Wazen WhatsApp API",
  "author": "IrixSoft <info@irixsoft.com>",
  "license": "MIT",
  "homepage": "https://wazen.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/irixsoft/wazen-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/irixsoft/wazen-ts-sdk/issues"
  },
  "keywords": [
    "wazen",
    "whatsapp",
    "api",
    "sdk",
    "typescript",
    "messaging"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
